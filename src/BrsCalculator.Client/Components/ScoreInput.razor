@using BrsCalculator.Domain.Brs

<MudNumericField T="decimal?"
                 Value="_value"
                 ValueChanged="HandleValueChangedAsync"
                 Step="@ScorePrecision.ScoreStep"
                 Min="0m"
                 Max="@MaxScore"
                 Culture="AppCulture.Russian"
                 Format="@ScorePrecision.InputFormat"
                 Margin="Margin.Dense"
                 Style="max-width:130px"
                 Disabled="@Disabled"
                 @onfocus="HandleFocus"
                 OnBlur="HandleBlurAsync" />

@code {
    [Parameter] public decimal? Score { get; set; }
    [Parameter] public decimal MaxScore { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<decimal?> OnCommit { get; set; }

    private decimal? _value;
    private decimal? _lastCommitted;
    private bool _focused;

    protected override void OnParametersSet()
    {
        if (!_focused)
        {
            _value = AppCulture.RoundScore(Score);
            _lastCommitted = _value;
        }
    }

    private void HandleFocus(FocusEventArgs _) => _focused = true;

    private async Task HandleValueChangedAsync(decimal? newValue)
    {
        var previous = _value;
        _value = newValue;

        if (_focused && IsStepChange(previous, newValue))
            await CommitAsync();
    }

    private async Task HandleBlurAsync(FocusEventArgs _)
    {
        _focused = false;
        await CommitAsync();
    }

    private static bool IsStepChange(decimal? before, decimal? after)
    {
        var delta = Math.Abs((after ?? 0m) - (before ?? 0m));
        return delta == ScorePrecision.ScoreStep;
    }

    private async Task CommitAsync()
    {
        _value = AppCulture.RoundScore(_value);
        if (_value == _lastCommitted)
            return;

        _lastCommitted = _value;
        await OnCommit.InvokeAsync(_value);
    }
}
