@page "/reset-password"
@attribute [AllowAnonymous]
@inject AuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudPaper Class="pa-6 mx-auto" Style="max-width:480px">
    <MudText Typo="Typo.h5" Class="mb-4">Новый пароль</MudText>
    <MudTextField @bind-Value="_email" Label="Email" />
    <MudTextField @bind-Value="_token" Label="Токен сброса" Lines="2" Class="mt-2" />
    <MudTextField @bind-Value="_password" Label="Новый пароль" InputType="InputType.Password" Class="mt-2" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="SubmitAsync" Disabled="_busy">
        Сохранить
    </MudButton>
    <MudLink Href="/login" Class="mt-3 d-block">Вход</MudLink>
</MudPaper>

@code {
    private string _email = "";
    private string _token = "";
    private string _password = "";
    private bool _busy;

    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Email)) _email = Email;
        if (!string.IsNullOrEmpty(Token)) _token = Token;
    }

    private async Task SubmitAsync()
    {
        _busy = true;
        var (ok, err) = await Auth.ResetPasswordAsync(new ResetPasswordRequest(_email, _token, _password));
        _busy = false;
        if (!ok)
        {
            Snackbar.Add(err ?? "Ошибка", Severity.Error);
            return;
        }
        Snackbar.Add("Пароль изменён", Severity.Success);
        Nav.NavigateTo("/login");
    }
}
