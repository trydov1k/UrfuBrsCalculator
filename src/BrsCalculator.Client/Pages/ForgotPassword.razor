@page "/forgot-password"
@attribute [AllowAnonymous]
@inject AuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudPaper Class="pa-6 mx-auto" Style="max-width:480px">
    <MudText Typo="Typo.h5" Class="mb-4">Восстановление пароля</MudText>
    <MudTextField @bind-Value="_email" Label="Email" InputType="InputType.Email" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="SubmitAsync" Disabled="_busy">
        Отправить
    </MudButton>
    <MudLink Href="/login" Class="mt-3 d-block">Назад к входу</MudLink>

    @if (!string.IsNullOrEmpty(_devToken))
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">
            В MVP письма не отправляются. Токен сброса (только для разработки):
            <MudTextField Value="_devToken" ReadOnly="true" Lines="3" Class="mt-2" />
            <MudLink Href="@($"/reset-password?email={Uri.EscapeDataString(_email)}&token={Uri.EscapeDataString(_devToken)}")">
                Перейти к сбросу пароля
            </MudLink>
        </MudAlert>
    }
</MudPaper>

@code {
    private string _email = "";
    private string? _devToken;
    private bool _busy;

    private async Task SubmitAsync()
    {
        _busy = true;
        var (ok, token, _) = await Auth.ForgotPasswordAsync(_email);
        _busy = false;
        if (!ok)
        {
            Snackbar.Add("Запрос не выполнен", Severity.Error);
            return;
        }
        _devToken = token;
        Snackbar.Add("Если аккаунт существует, инструкции отправлены", Severity.Success);
    }
}
